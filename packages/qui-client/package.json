{
  "name": "qui-client",
  "version": "0.1.0",
  "description": "Standalone CLI client for q-ui-lib",
  "license": "MIT",
  "type": "commonjs",
  "keywords": [
    "qwik",
    "cli",
    "ui",
    "components",
    "q-ui-lib"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honzicekdev/q-ui-lib.git",
    "directory": "packages/qui-client"
  },
  "bugs": {
    "url": "https://github.com/honzicekdev/q-ui-lib/issues"
  },
  "homepage": "https://github.com/honzicekdev/q-ui-lib/tree/main/packages/qui-client#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "qui": "./bin/qui.js"
  },
  "scripts": {
    "prepublishOnly": "npm pack --dry-run",
    "start": "node ./bin/qui.js",
    "test": "node --test test/parser.test.js test/config.test.js test/policy.test.js test/source-resolver.test.js test/component-catalog.test.js test/cli-demo-smoke.test.js test/init-smoke.test.js test/connect-smoke.test.js",
    "generate-meta": "node ./scripts/generate-meta.mjs --app-root ../.. --components-dir ../../components"
  },
  "dependencies": {
    "ts-morph": "^27.0.2"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "templates",
    "CHANGELOG.md",
    "README.md"
  ]
}
