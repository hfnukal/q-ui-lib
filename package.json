{
  "name": "q-ui-lib",
  "version": "0.1.0",
  "description": "Custom Qwik UI component library with CLI",
  "private": true,
  "workspaces": [
    "packages/*",
    "demo",
    "template"
  ],
  "main": "index.js",
  "exports": {
    "./utilities": "./components/utilities/index.ts",
    "./utilities/*": "./components/utilities/*.ts",
    "./cli": "./cli/index.js"
  },
  "bin": {
    "q-ui-lib": "./cli/index.js",
    "qui": "./cli/index.js"
  },
  "scripts": {
    "test:qui-client": "npm test -w qui-client",
    "publish:qui-client": "npm publish -w qui-client --access public",
    "build": "echo 'No build step needed for library'",
    "qui": "qui",
    "qui:createdemo": "qui init demo && (cd demo && qui add --all base --force && qui generate-demo) && echo \"\nDemo created. Run:\\ncd demo\\nnpm run dev\""
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@qwik-ui/headless": "^0.7.4",
    "chalk": "^4.1.2",
    "chart.js": "^4.5.1",
    "commander": "^11.0.0",
    "dayjs": "^1.11.13",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.1.1",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@qwikest/icons": "^0.0.13",
    "qui-client": "^0.1.0"
  }
}
