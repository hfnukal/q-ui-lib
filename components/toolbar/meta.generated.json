{
  "name": "toolbar",
  "title": "Toolbar",
  "version": "1.1.0",
  "kind": "compound",
  "registry": "base",
  "dependencies": [
    "separator"
  ],
  "apiTree": {
    "Root": {
      "params": {
        "orientation": [
          "horizontal",
          "vertical"
        ],
        "role": [
          "menubar",
          "toolbar"
        ],
        "aria-label": "string"
      },
      "slot": true,
      "children": {
        "Group": {
          "params": {
            "aria-label": "string"
          },
          "slot": true
        },
        "Separator": {
          "params": {
            "orientation": [
              "horizontal",
              "vertical"
            ]
          }
        },
        "Spacer": {},
        "Button": {
          "params": {
            "type": [
              "button",
              "reset",
              "submit"
            ]
          },
          "slot": true
        },
        "Link": {
          "slot": true
        }
      }
    }
  }
}
