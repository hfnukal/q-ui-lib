{
  "name": "sidebar",
  "title": "Sidebar",
  "version": "1.0.0",
  "kind": "compound",
  "registry": "base",
  "dependencies": [],
  "npmDependencies": [
    "@builder.io/qwik"
  ],
  "apiTree": {
    "Root": {
      "params": {
        "side": [
          "left",
          "right"
        ]
      },
      "slot": true,
      "children": {
        "Provider": {
          "params": {
            "defaultCollapsed": "boolean"
          },
          "slot": true
        },
        "labelAbbrev": {},
        "Inset": {
          "slot": true
        },
        "Header": {
          "slot": true,
          "children": {
            "HeaderTitle": {
              "slot": true
            }
          }
        },
        "Footer": {
          "slot": true
        },
        "Content": {
          "slot": true
        },
        "Group": {
          "slot": true,
          "children": {
            "GroupLabel": {
              "slot": true
            },
            "GroupContent": {
              "slot": true
            }
          }
        },
        "Menu": {
          "slot": true,
          "children": {
            "MenuItem": {
              "slot": true
            },
            "MenuButton": {
              "params": {
                "active": "boolean",
                "variant": [
                  "default",
                  "outline"
                ],
                "itemLabel": "string"
              },
              "slot": true
            },
            "MenuIcon": {
              "slot": true
            },
            "MenuLabel": {
              "params": {
                "abbrevSource": "string"
              },
              "slot": true
            },
            "MenuAction": {
              "slot": true
            }
          }
        },
        "Separator": {},
        "Trigger": {
          "slot": true
        },
        "Rail": {}
      }
    }
  }
}
